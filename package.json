{
  "name": "interlis-language-tools-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.14.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint . --no-error-on-unmatched-pattern",
    "format:check": "prettier --check .",
    "check": "pnpm build && pnpm lint && pnpm typecheck && pnpm test && pnpm test:snapshot",
    "test:snapshot": "node --test test/npm/*.test.mjs",
    "test:repository-network": "node scripts/smoke-browser-repositories.mjs",
    "snapshot:prepare": "node scripts/prepare-npm-snapshot.mjs",
    "pack:verify": "node scripts/verify-packages.mjs",
    "package:vsix": "pnpm build && node scripts/package-vsix.mjs",
    "licenses:check": "node scripts/check-licenses.mjs",
    "security:check": "pnpm audit --prod --audit-level high",
    "changeset": "changeset"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@eslint/js": "^9.39.1",
    "@types/node": "^22.19.0",
    "@vitest/coverage-v8": "^4.0.16",
    "@vscode/vsce": "3.9.2",
    "esbuild": "0.28.1",
    "eslint": "^9.39.1",
    "ovsx": "1.0.2",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.1",
    "vitest": "^4.0.16"
  }
}
