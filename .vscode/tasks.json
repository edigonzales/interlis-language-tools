{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build language tools",
      "type": "shell",
      "command": "corepack pnpm build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$tsc"
    },
    {
      "label": "build compiler WASM",
      "type": "shell",
      "command": "./scripts/build-wasm.sh",
      "options": {
        "cwd": "${workspaceFolder}/../ilic-fork"
      },
      "problemMatcher": []
    }
  ]
}
