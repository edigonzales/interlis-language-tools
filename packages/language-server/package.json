{
  "name": "@ilic/language-server",
  "version": "1.0.0-rc.1",
  "description": "Node.js and browser-worker LSP adapters for INTERLIS.",
  "license": "MIT",
  "author": "edigonzales",
  "keywords": [
    "interlis",
    "lsp",
    "language-server",
    "vscode",
    "theia"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/edigonzales/interlis-language-tools.git",
    "directory": "packages/language-server"
  },
  "homepage": "https://github.com/edigonzales/interlis-language-tools#readme",
  "bugs": {
    "url": "https://github.com/edigonzales/interlis-language-tools/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "default": "./dist/browser.js"
    },
    "./protocol": {
      "types": "./dist/protocol.d.ts",
      "default": "./dist/protocol.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "typecheck": "tsc -b tsconfig.json --pretty false",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@ilic/docx": "workspace:*",
    "@ilic/language-service": "workspace:*",
    "vscode-languageserver": "^9.0.1"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18"
  }
}
