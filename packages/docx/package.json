{
  "name": "@ilic/docx",
  "version": "0.1.0-next.0",
  "description": "DOCX documentation generation from INTERLIS semantic snapshots.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "typecheck": "tsc -b tsconfig.json --pretty false",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@ilic/language-service": "workspace:*",
    "docx": "^9.5.1"
  },
  "devDependencies": {
    "fflate": "^0.8.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
