{
  "name": "@ilic/docx",
  "version": "0.1.0",
  "description": "DOCX documentation generation from INTERLIS semantic snapshots.",
  "license": "MIT",
  "author": "edigonzales",
  "keywords": [
    "interlis",
    "docx",
    "documentation",
    "generator"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/edigonzales/interlis-language-tools.git",
    "directory": "packages/docx"
  },
  "homepage": "https://github.com/edigonzales/interlis-language-tools#readme",
  "bugs": {
    "url": "https://github.com/edigonzales/interlis-language-tools/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "typecheck": "tsc -b tsconfig.json --pretty false",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@ilic/language-service": "workspace:*",
    "docx": "^9.5.1"
  },
  "devDependencies": {
    "fflate": "^0.8.2"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18"
  }
}
