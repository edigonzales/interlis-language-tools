{
  "name": "@ilic/diagram",
  "version": "1.0.0-rc.1",
  "description": "Sprotty/ELK live UML diagrams for INTERLIS semantic snapshots.",
  "license": "MIT",
  "author": "edigonzales",
  "keywords": [
    "interlis",
    "diagram",
    "sprotty",
    "elk",
    "svg"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/edigonzales/interlis-language-tools.git",
    "directory": "packages/diagram"
  },
  "homepage": "https://github.com/edigonzales/interlis-language-tools#readme",
  "bugs": {
    "url": "https://github.com/edigonzales/interlis-language-tools/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "typecheck": "tsc -b tsconfig.json --pretty false",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@ilic/language-service": "workspace:*",
    "elkjs": "^0.11.0",
    "sprotty": "^1.4.0",
    "sprotty-protocol": "^1.4.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18"
  }
}
