{
  "name": "@ilic/diagram",
  "version": "0.1.0-next.0",
  "description": "Sprotty/ELK live UML diagrams for INTERLIS semantic snapshots.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
